# Шаблон .env для продакшена. Скопировать в /opt/notebook-grader/.env,
# chmod 600, владелец notebook-grader:notebook-grader.

NBGRADER_ENVIRONMENT=production

# Сгенерировать: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
NBGRADER_SECRET_KEY=REPLACE_ME_WITH_token_urlsafe_32

# Сгенерировать пароль: python3 -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_USER=grader
POSTGRES_PASSWORD=REPLACE_ME_STRONG_RANDOM_PASSWORD
POSTGRES_DB=grader_db

# user/password/db должны совпадать с POSTGRES_* выше.
NBGRADER_DATABASE_URL=postgresql://grader:REPLACE_ME_STRONG_RANDOM_PASSWORD@127.0.0.1:5432/grader_db

# Домен и публичный IP сервера. 127.0.0.1/localhost не нужны:
# /healthz и /readyz обходят TrustedHostMiddleware в коде.
NBGRADER_ALLOWED_HOSTS=mydomain.example,123.123.123.123

NBGRADER_CORS_ORIGINS=https://mydomain.example

# По умолчанию in-memory (корректно при --workers 1).
# При >1 воркера задать redis://host:port.
# NBGRADER_RATELIMIT_STORAGE_URI=memory://

# Должен совпадать с первым значением в NBGRADER_ALLOWED_HOSTS и DNS A-записью.
DOMAIN=mydomain.example
