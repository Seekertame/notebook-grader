# Скопируйте этот файл в .env и заполните значения

# Окружение запуска: development | production
# В production отключаются /docs, /redoc, /openapi.json и требуются
# NBGRADER_ALLOWED_HOSTS и NBGRADER_CORS_ORIGINS.
NBGRADER_ENVIRONMENT=development

# Секретный ключ для подписи JWT-токенов.
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(32))"
NBGRADER_SECRET_KEY=change_me_generate_random_secret

# Учётные данные PostgreSQL (используются docker-compose для инициализации БД)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=grader_db

# Строка подключения к PostgreSQL для приложения.
# Должна соответствовать значениям POSTGRES_* выше.
NBGRADER_DATABASE_URL=postgresql://postgres:change_me_strong_password@localhost:5432/grader_db

# Rate-limit storage. По умолчанию in-memory (memory://) — лимиты работают
# в рамках одного процесса uvicorn. Для курсовой этого достаточно.
# ВАЖНО: запускайте uvicorn с одним воркером (--workers 1), иначе
# счётчики не делятся между процессами и эффективный лимит умножается на N.
# Если воркеров > 1 — задайте redis://host:port для общего хранилища.
# NBGRADER_RATELIMIT_STORAGE_URI=memory://

# Белый список хостов для TrustedHostMiddleware (защита от Host header injection).
# Comma-separated, без пробелов. В production обязательно.
# ВАЖНО: указывайте ОБА — доменное имя и IP сервера. Иначе health-check
# или curl по IP вернёт 400 Invalid host header.
# Пример: grader.example.com,api.grader.example.com,203.0.113.42
NBGRADER_ALLOWED_HOSTS=localhost,127.0.0.1

# Белый список Origin для CORSMiddleware. Comma-separated, с указанием схемы.
# В production обязательно. Не используйте "*" вместе с allow_credentials.
# Пример: https://grader.example.com,https://admin.grader.example.com
NBGRADER_CORS_ORIGINS=http://localhost:8000
